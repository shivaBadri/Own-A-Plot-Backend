# ---------------------------------------------------------------------------
# Database — Neon PostgreSQL
# Use the POOLED connection string for the app (it ends in "-pooler").
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://neondb_owner:npg_smHvpby2I1fW@ep-wispy-king-ao32x8df.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"
"
# NOTE ON MIGRATIONS: Neon's pooled endpoint cannot run DDL. When running
# `prisma migrate deploy`, point DATABASE_URL at the DIRECT (non-pooled) string
# for that command only — the one WITHOUT "-pooler" in the host.

# ---------------------------------------------------------------------------
# Auth — sign the admin session JWT.
# Generate with:  openssl rand -base64 32
# There is a dev fallback in code; leaving this unset in production means every
# deploy can forge an admin session. Set it.
# ---------------------------------------------------------------------------
AUTH_SECRET="replace-with-a-long-random-secret"

# ---------------------------------------------------------------------------
# Cloudinary — Dashboard > Account Details
# ---------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ---------------------------------------------------------------------------
# Absolute URLs for sitemap.xml, robots.txt, and OpenGraph metadata.
# No trailing slash.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# Seed only — creates the first admin account. Change the password after the
# first sign-in, then remove these.
# ---------------------------------------------------------------------------
SEED_ADMIN_EMAIL="admin@ownaplot.com"
SEED_ADMIN_PASSWORD="changeme123"
